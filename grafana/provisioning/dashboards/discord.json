{
  "title": "Discord Voice Logger",
  "uid": "discord-voice",
  "tags": ["discord", "voice"],
  "schemaVersion": 38,
  "version": 9,
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},

  "templating": {
    "list": [
      {
        "name": "channel_var",
        "type": "query",
        "label": "Канал",
        "datasource": { "type": "influxdb", "uid": "influxdb-discord" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"voice_logs\", tag: \"channel_name\", predicate: (r) => r._measurement == \"voice_presence\")",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "hide": 0,
        "options": [],
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "participant_var",
        "type": "query",
        "label": "Участник",
        "datasource": { "type": "influxdb", "uid": "influxdb-discord" },
        "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"voice_logs\", tag: \"username\", predicate: (r) => r._measurement == \"voice_presence\")",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "hide": 0,
        "options": [],
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },

  "panels": [

    {
      "id": 5,
      "type": "table",
      "title": "Созвоны",
      "description": "Один ряд = один созвон. Колонки участников динамические. Фильтр [Канал] работает здесь; [Участник] — на нижних графиках.",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 12 },
      "options": {
        "showHeader": true,
        "footer": { "show": false },
        "sortBy": [{ "displayName": "Начало", "desc": true }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "_time": true, "Time": true, "_start": true, "_stop": true,
              "_measurement": true, "guild_id": true, "result": true, "table": true
            },
            "indexByName": {
              "channel_name": 0,
              "call_label": 1,
              "end_time": 2,
              "_duration": 3
            },
            "renameByName": {}
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "align": "left", "cellOptions": { "type": "auto" }, "filterable": true },
          "noValue": "—"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "_time" },        "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Time" },         "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "_start" },       "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "_stop" },        "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "_measurement" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "guild_id" },     "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "result" },       "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "table" },        "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "channel_name" }, "properties": [
            { "id": "displayName", "value": "Канал" },
            { "id": "custom.width", "value": 140 }
          ]},
          { "matcher": { "id": "byName", "options": "call_label" }, "properties": [
            { "id": "displayName", "value": "Начало" },
            { "id": "custom.width", "value": 180 }
          ]},
          { "matcher": { "id": "byName", "options": "end_time" }, "properties": [
            { "id": "displayName", "value": "Конец" },
            { "id": "custom.width", "value": 110 }
          ]},
          { "matcher": { "id": "byName", "options": "_duration" }, "properties": [
            { "id": "displayName", "value": "Длительность" },
            { "id": "unit", "value": "m" },
            { "id": "custom.width", "value": 140 },
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
            { "id": "color", "value": { "mode": "thresholds" } },
            { "id": "thresholds", "value": {
              "mode": "absolute",
              "steps": [
                { "color": "#57F287", "value": null },
                { "color": "#FEE75C", "value": 30 },
                { "color": "#ED4245", "value": 60 }
              ]
            }}
          ]},
          { "matcher": { "id": "byType", "options": "number" }, "properties": [
            { "id": "unit", "value": "m" },
            { "id": "custom.width", "value": 90 }
          ]}
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-discord" },
          "query": "import \"types\"\nimport \"strings\"\n\n// Получаем call_label'ы где участвовал выбранный участник\nlabels = from(bucket: \"voice_logs\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"call_session\" and r._field == \"duration_minutes\")\n  |> filter(fn: (r) => r.channel_name =~ /${channel_var}/)\n  |> filter(fn: (r) => r.participants_csv =~ /${participant_var}/)\n  |> group()\n  |> distinct(column: \"call_label\")\n  |> findColumn(fn: (key) => true, column: \"_value\")\n\nfrom(bucket: \"voice_logs\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"call_wide\")\n  |> filter(fn: (r) => r.channel_name =~ /${channel_var}/)\n  |> filter(fn: (r) => contains(value: r.call_label, set: labels))\n  |> filter(fn: (r) => types.isType(v: r._value, type: \"float\"))\n  |> map(fn: (r) => ({r with call_label: strings.trimPrefix(v: r.call_label, prefix: r.channel_name + \" \")}))\n  |> group(columns: [\"call_label\", \"channel_name\", \"guild_id\", \"_field\"])\n  |> last()\n  |> group(columns: [\"call_label\", \"channel_name\", \"guild_id\"])\n  |> pivot(rowKey: [\"_time\", \"end_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> group()",
          "refId": "A"
        }
      ]
    },

    {
      "id": 21,
      "type": "timeseries",
      "pluginVersion": "12.4.0",
      "title": "Созвоны по дням",
      "description": "Количество созвонов за каждый день периода",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 9 },
      "options": {
        "tooltip": { "mode": "single", "sort": "none", "hideZeros": false },
        "legend": { "showLegend": false, "displayMode": "hidden", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "#5865F2" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] },
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "lineWidth": 1,
            "fillOpacity": 80,
            "gradientMode": "none",
            "spanNulls": false,
            "insertNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "stacking": { "mode": "none", "group": "A" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "axisBorderShow": false,
            "scaleDistribution": { "type": "linear" },
            "axisCenteredZero": false,
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "thresholdsStyle": { "mode": "off" },
            "axisSoftMin": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "duration_minutes" },
            "properties": [{ "id": "displayName", "value": "Созвонов" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-discord" },
          "query": "from(bucket: \"voice_logs\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"call_session\" and r._field == \"duration_minutes\")\n  |> filter(fn: (r) => r.channel_name =~ /${channel_var}/)\n  |> filter(fn: (r) => r.participants_csv =~ /${participant_var}/)\n  |> group(columns: [\"_field\", \"_measurement\"])\n  |> aggregateWindow(every: 1d, fn: count, createEmpty: false)",
          "refId": "A"
        }
      ]
    },

    {
      "id": 22,
      "type": "bargauge",
      "title": "Длительность созвонов",
      "description": "Каждый бар = один созвон, самые длинные сверху. Зелёный <30м, жёлтый 30-60м, красный >1ч.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 9 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizHeight": 15,
        "namePlacement": "auto",
        "legend": { "displayMode": "hidden" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#57F287", "value": null },
              { "color": "#FEE75C", "value": 30 },
              { "color": "#ED4245", "value": 60 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-discord" },
          "query": "from(bucket: \"voice_logs\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"call_session\" and r._field == \"duration_minutes\")\n  |> filter(fn: (r) => r.channel_name =~ /${channel_var}/)\n  |> filter(fn: (r) => r.participants_csv =~ /${participant_var}/)\n  |> group()\n  |> sort(columns: [\"_value\"], desc: true)\n  |> limit(n: 50)\n  |> map(fn: (r) => ({_time: r._time, _field: r.call_label, _value: r._value}))\n  |> group(columns: [\"_field\"])",
          "refId": "A"
        }
      ]
    }

  ]
}
